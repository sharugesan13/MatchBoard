@model MatchBoard.Web.Models.Project
@{
    ViewData["Title"] = "Submit Proposal";
}
<style>
@@keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
.form-pg { animation: fadeUp 0.4s ease both; }
.form-box {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; padding: 34px;
    backdrop-filter: blur(18px);
    position: relative; overflow: hidden;
    box-shadow: 0 0 40px rgba(0,0,0,0.3);
}
.form-box::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(167,139,250,0.5), transparent);
}
.form-pg-header { margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.06); }
.form-pg-header h2 { font-size: 18px; font-weight: 700; color: #f8fafc !important; margin-bottom: 5px; }
.form-pg-header p { font-size: 13px; color: #475569; margin: 0; }
.form-footer { padding-top: 6px; display: flex; gap: 10px; align-items: center; }
</style>

<div class="form-pg">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="form-box">
                <div class="form-pg-header">
                    <h2>Submit Project Proposal</h2>
                    <p>Your identity stays hidden until a match is confirmed.</p>
                </div>
                <form method="post" action="/Project/Create">
                    <div class="mb-3">
                        <label class="form-label">Project Title</label>
                        <input type="text" name="Title" class="form-control" required placeholder="e.g. AI-Based Study Planner" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Abstract</label>
                        <textarea name="Abstract" class="form-control" rows="4" required placeholder="Describe your research project and objectives..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Technical Stack</label>
                        <input type="text" name="TechStack" class="form-control" required placeholder="e.g. React, Python, TensorFlow" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Research Area</label>
                        <select name="ResearchArea" class="form-select" required>
                            <option value="">-- Select Area --</option>
                            <option value="Artificial Intelligence">Artificial Intelligence</option>
                            <option value="Web Development">Web Development</option>
                            <option value="Cybersecurity">Cybersecurity</option>
                            <option value="Cloud Computing">Cloud Computing</option>
                            <option value="Machine Learning">Machine Learning</option>
                            <option value="Mobile Development">Mobile Development</option>
                            <option value="Internet of Things">Internet of Things</option>
                        </select>
                    </div>
                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary">Submit Proposal</button>
                        <a href="/Project/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>