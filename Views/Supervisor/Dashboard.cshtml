@model SupervisorDashboardViewModel
@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Supervisor Dashboard</h1>
        <p class="text-secondary mb-0">Track your current blind review activity and update your research expertise.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="SetExpertise" class="btn btn-outline-primary">Set Expertise</a>
        <a asp-action="Browse" class="btn btn-primary">Open Blind Review</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="stat-label">Total interests</div>
                <div class="stat-value">@Model.TotalInterests</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="stat-label">Open reviews</div>
                <div class="stat-value">@Model.OpenReviews</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="stat-label">Expertise areas</div>
                <div class="stat-value">@Model.ExpertiseAreas.Count</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5>Your expertise</h5>
                @if (!Model.ExpertiseAreas.Any())
                {
                    <p class="text-secondary">No expertise has been selected yet.</p>
                    <a asp-action="SetExpertise" class="btn btn-outline-primary btn-sm">Choose research areas</a>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        @foreach (var area in Model.ExpertiseAreas)
                        {
                            <span class="badge text-bg-light border">@area</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Recent activity</h5>
                    <a asp-action="MyMatches" class="btn btn-outline-secondary btn-sm">View all</a>
                </div>
                @if (!Model.RecentMatches.Any())
                {
                    <p class="text-secondary mb-0">No supervisor activity yet. Start by selecting expertise and browsing projects.</p>
                }
                else
                {
                    @foreach (var match in Model.RecentMatches)
                    {
                        <div class="match-row">
                            <div>
                                <div class="fw-semibold">@match.ProjectTitle</div>
                                <div class="small text-secondary">@match.ResearchArea</div>
                            </div>
                            <div class="text-end">
                                <span class="badge @(match.IsRevealed ? "text-bg-success" : "text-bg-warning")">
                                    @(match.IsRevealed ? "Matched" : "Under Review")
                                </span>
                                <div class="small text-secondary mt-1">@match.MatchedAt.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
