@model SupervisorExpertiseViewModel
@{
    ViewData["Title"] = "Set Expertise";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-2">Research area selection</h1>
                <p class="text-secondary">Choose the areas that match your expertise. The blind review dashboard will only show proposals in these areas.</p>

                <form asp-action="SetExpertise" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3 mt-1">
                        @for (var i = 0; i < Model.Areas.Count; i++)
                        {
                            <div class="col-md-6">
                                <div class="area-card">
                                    <input type="hidden" asp-for="Areas[i].Id" />
                                    <input type="hidden" asp-for="Areas[i].Name" />
                                    <input type="hidden" asp-for="Areas[i].Tag" />
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedAreaIds"
                                               value="@Model.Areas[i].Id"
                                               id="area_@Model.Areas[i].Id"
                                               @(Model.Areas[i].IsSelected ? "checked" : null) />
                                        <label class="form-check-label w-100" for="area_@Model.Areas[i].Id">
                                            <span class="fw-semibold">@Model.Areas[i].Name</span>
                                            <span class="badge text-bg-light border float-end">@Model.Areas[i].Tag</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Save expertise</button>
                        <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
