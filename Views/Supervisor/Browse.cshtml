@model IReadOnlyList<BlindReviewViewModel>
@{
    ViewData["Title"] = "Blind Review";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Blind Review Dashboard</h1>
        <p class="text-secondary mb-0">Student identities are hidden. Supervisors only see proposal content and research area alignment.</p>
    </div>
    <a asp-action="SetExpertise" class="btn btn-outline-primary">Change expertise</a>
</div>

<div class="alert alert-info shadow-sm border-0">
    The list below deliberately hides student name, email, and ID. That information is not part of this supervisor module view.
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5 class="mb-2">No matching projects available</h5>
            <p class="text-secondary mb-3">Either you have not selected any expertise areas yet, or there are no pending proposals in those areas.</p>
            <a asp-action="SetExpertise" class="btn btn-primary">Set research expertise</a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var project in Model)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm h-100 @(project.HasExpressedInterest ? "interest-card" : string.Empty)">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                            <div>
                                <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                                    <h5 class="mb-0">@project.Title</h5>
                                    <span class="badge text-bg-light border">@project.ResearchArea</span>
                                </div>
                                <p class="text-secondary mb-3">@project.Abstract</p>
                                <div class="small mb-1"><strong>Tech stack:</strong> @project.TechStack</div>
                                <div class="small text-secondary">Submitted on @project.SubmittedAt.ToString("dd MMM yyyy")</div>
                            </div>
                            <div class="text-lg-end">
                                @if (project.HasExpressedInterest)
                                {
                                    <span class="badge text-bg-success px-3 py-2">Interest already expressed</span>
                                }
                                else
                                {
                                    <form asp-action="ExpressInterest" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="projectId" value="@project.ProjectId" />
                                        <button type="submit" class="btn btn-primary">Express interest</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
