@model IEnumerable<MatchBoard.Web.Models.Project>
@{
    ViewData["Title"] = "My Projects";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Project Proposals</h2>
        <a asp-action="Create" class="btn btn-primary">+ New Proposal</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">You have no project proposals yet.</div>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Research Area</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model)
                {
                    <tr>
                        <td>@project.Title</td>
                        <td>@project.ResearchArea</td>
                        <td>
                            <span class="badge 
                                @(project.Status == "Matched" ? "bg-success" : 
                                  project.Status == "UnderReview" ? "bg-warning" : "bg-secondary")">
                                @project.Status
                            </span>
                        </td>
                        <td>@project.SubmittedAt.ToShortDateString()</td>
                        <td>
                            @if (project.Status == "Pending")
                            {
                                <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <form method="post" asp-action="Withdraw" asp-route-id="@project.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Withdraw this proposal?')">Withdraw</button>
                                </form>
                            }
                            @if (project.Status == "Matched" && project.IdentityRevealed)
                            {
                                <span class="text-success">✔ Supervisor Revealed</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
